# =================================================================
# Meat City - Environment Variables
# =================================================================

# --- Database Mode ---
# Set to 'true' to use the local mock JSON database (development only)
# Set to 'false' or remove for production Supabase connection
NEXT_PUBLIC_USE_MOCK_DB=false

# --- Supabase Configuration ---
# Find these in your Supabase Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only: Required for admin operations (creating delivery partners)
# Find this in Supabase Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Razorpay Configuration ---
# Find these in your Razorpay Dashboard -> Settings -> API Keys
# Use rzp_live_* keys for production, rzp_test_* for testing
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# --- Application Configuration ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
